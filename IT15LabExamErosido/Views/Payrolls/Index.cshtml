@model IEnumerable<IT15LabExamErosido.Models.Payroll>

@{
    ViewData["Title"] = "All Payroll Records";
}

<h1>All Payroll Records</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Payroll Record</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Payroll ID</th>
            <th>Employee</th>
            <th>Date</th>
            <th>Days Worked</th>
            <th>Daily Rate</th>
            <th>Gross Pay</th>
            <th>Deduction</th>
            <th>Net Pay</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="9" class="text-center">No payroll records found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.PayrollId</td>
                    <td>@item.Employee?.FirstName @item.Employee?.LastName</td>
                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                    <td>@item.DaysWorked</td>
                    <td>@(item.Employee?.DailyRate.ToString("C") ?? "N/A")</td>
                    <td class="text-success fw-bold">@item.GrossPay.ToString("C")</td>
                    <td class="text-danger">@item.Deduction.ToString("C")</td>
                    <td class="text-primary fw-bold">@item.NetPay.ToString("C")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.PayrollId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.PayrollId" class="btn btn-sm btn-danger">Delete</a>
                        <a asp-controller="Employees" asp-action="Edit" asp-route-id="@item.EmployeeId" class="btn btn-sm btn-info">View Employee</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>