@model IT15LabExamErosido.Models.Payroll

@{
    ViewData["Title"] = "Delete Payroll";
}

<h1>Delete Payroll Record</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this payroll record?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-3">Payroll ID</dt>
        <dd class="col-sm-9">@Model.PayrollId</dd>
        
        <dt class="col-sm-3">Employee</dt>
        <dd class="col-sm-9">@Model.Employee?.FirstName @Model.Employee?.LastName</dd>
        
        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>
        
        <dt class="col-sm-3">Days Worked</dt>
        <dd class="col-sm-9">@Model.DaysWorked</dd>
        
        <dt class="col-sm-3">Gross Pay</dt>
        <dd class="col-sm-9 text-success">@Model.GrossPay.ToString("C")</dd>
        
        <dt class="col-sm-3">Deduction</dt>
        <dd class="col-sm-9 text-danger">@Model.Deduction.ToString("C")</dd>
        
        <dt class="col-sm-3">Net Pay</dt>
        <dd class="col-sm-9 text-primary fw-bold">@Model.NetPay.ToString("C")</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="PayrollId" />
        <input type="submit" value="Delete Permanently" class="btn btn-danger" />
        <a asp-action="EmployeePayrolls" asp-route-id="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
    </form>
</div>